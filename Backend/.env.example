# Environment Configuration

# Local dev DB (use: uv run scripts/create_or_run_dev_DB.py)
DATABASE_URL="mysql+pymysql://root:rootpassword@127.0.0.1:3306/scores-local"

# google stuff
GOOGLE_CLIENT_ID=app_client_id_here
GOOGLE_CLIENT_SECRET=app_client_secret_here

# attendance stuff
JWT_SECRET=

# certificate stuff
CERTIFICATE_API_URL=http://localhost:8000

# clerk stuff
CLERK_JWKS_URL=

# observability (OTel)
OTEL_SERVICE_NAME=score-leaderboard-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACING_SAMPLING_RATE=1.0
OTEL_METRIC_EXPORT_INTERVAL_MS=60000